rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Secured Users collection and localStorageSync subcollection
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /localStorageSync/{key} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create, update: if request.auth != null
          && request.auth.uid == userId
          && isValidLocalStorageSync(request.resource.data);
        allow delete: if request.auth != null && request.auth.uid == userId;
      }

      // Canonical athlete stats (users/{uid}/profile/stats) — written by the
      // app, read by the app and the future videogame. Owner-only.
      match /profile/{docId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null
          && request.auth.uid == userId
          && isValidAthleteStats(request.resource.data);
      }
    }

    // Public program catalog: anyone can browse; only signed-in athletes can
    // publish, and each author manages exclusively their own entries.
    match /programCatalog/{programId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.authorUid == request.auth.uid
        && isValidCatalogProgram(request.resource.data);
      allow update: if request.auth != null
        && resource.data.authorUid == request.auth.uid
        && request.resource.data.authorUid == request.auth.uid
        && isValidCatalogProgram(request.resource.data);
      allow delete: if request.auth != null
        && resource.data.authorUid == request.auth.uid;
    }
  }

  // Light schema guard for the stats snapshot (client-authoritative data).
  function isValidAthleteStats(data) {
    return data.keys().hasAll(['schemaVersion', 'updatedAt'])
      && data.schemaVersion is int
      && data.updatedAt is string && data.updatedAt.size() <= 128
      && data.keys().size() <= 40;
  }

  // Schema guard for public catalog entries (program travels as JSON string).
  function isValidCatalogProgram(data) {
    return data.keys().hasAll(['title', 'authorUid', 'authorName', 'updatedAt', 'programJson'])
      && data.title is string && data.title.size() >= 1 && data.title.size() <= 120
      && data.authorUid is string && data.authorUid.size() <= 128
      && data.authorName is string && data.authorName.size() <= 80
      && data.updatedAt is string && data.updatedAt.size() <= 128
      && data.programJson is string && data.programJson.size() <= 1000000
      && data.keys().size() <= 12;
  }

  // Schema & Type validation helper function
  function isValidLocalStorageSync(data) {
    return data.keys().hasAll(['key', 'value', 'updatedAt'])
      && data.keys().size() == 3
      && data.key is string && data.key.size() <= 512
      && data.value is string && data.value.size() <= 1048576  // up to 1MB of JSON string
      && data.updatedAt is string && data.updatedAt.size() <= 128;
  }
}
